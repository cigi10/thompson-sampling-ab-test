import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

np.random.seed(42)

# ── Block 1: Load data ──────────────────────────────────────────
df = pd.read_csv('cookie_cats.csv')

gate_30 = df[df['version'] == 'gate_30']['retention_1'].values
gate_40 = df[df['version'] == 'gate_40']['retention_1'].values

mu_A    = gate_30.mean()
mu_B    = gate_40.mean()
mu_star = max(mu_A, mu_B) # It represents the oracle best possible expected reward

print(f"True mean A (gate_30): {mu_A:.4f}")
print(f"True mean B (gate_40): {mu_B:.4f}")
print(f"Oracle (mu*):          {mu_star:.4f}")

# ── Block 2: Agent setup ────────────────────────────────────────
alpha = [1, 1]   # [Model A, Model B]
beta  = [1, 1]

N                 = 10000
cumulative_regret = []
total_regret      = 0
choices           = []

# ── Block 3: Thompson Sampling loop ────────────────────────────
for _ in range(N):

    # Step 1 — sample from each posterior
    theta_A = np.random.beta(alpha[0], beta[0])
    theta_B = np.random.beta(alpha[1], beta[1])

    # Step 2 — pick the higher sample
    chosen = 0 if theta_A > theta_B else 1
    choices.append(chosen)

    # Step 3 — observe reward (one simulated streaming user)
    if chosen == 0:
        reward = np.random.choice(gate_30)
        # To simulate a streaming user by randomly sampling from historical data.
    else:
        reward = np.random.choice(gate_40)



    # Step 4 — update only the chosen model's posterior
    alpha[chosen] += reward
    beta[chosen]  += (1 - reward)

    # Step 5 — record regret
    mu_chosen    = mu_A if chosen == 0 else mu_B
    total_regret += (mu_star - mu_chosen) # Regret is defined using expected rewards, not sampled rewards, to reduce noise.
    cumulative_regret.append(total_regret)

# Summary
n_A = choices.count(0)
n_B = choices.count(1)
print(f"Final cumulative regret : {total_regret:.4f}")
print(f"Model A chosen: {n_A} times ({100*n_A/N:.1f}%)")
print(f"Model B chosen: {n_B} times ({100*n_B/N:.1f}%)")

# ── Block 4: Plot ───────────────────────────────────────────────
fig, axes = plt.subplots(1, 2, figsize=(14, 5))

# Cumulative regret curve
axes[0].plot(cumulative_regret, color='steelblue', linewidth=1.5)
axes[0].axvline(x=500, color='gray', linestyle='--', alpha=0.6, label='~Exploration ends')
# Detect when convergence actually happens (data-driven)

axes[0].set_xlabel('Iterations')
axes[0].set_ylabel('Cumulative Regret')
axes[0].set_title('Cumulative Regret over 10,000 Iterations')
axes[0].legend()
axes[0].grid(alpha=0.3)

# Model selection over time
rolling_choice = pd.Series(choices).rolling(200).mean()
axes[1].plot(rolling_choice, color='coral', linewidth=1.5)
axes[1].axhline(y=0.5, color='gray', linestyle='--', alpha=0.6, label='50/50 baseline')
axes[1].set_xlabel('Iterations')
axes[1].set_ylabel('Fraction choosing Model B')
axes[1].set_title('Model Selection Over Time (rolling avg)')
axes[1].legend()
axes[1].grid(alpha=0.3)

plt.tight_layout()
plt.show()
